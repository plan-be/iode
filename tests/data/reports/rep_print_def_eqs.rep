$ report testing printing IODE object

$indent
$noparsing
$goto continue {%0% >= 2}
    $show Syntax: rep_fns input_dir output_dir
    $show Syntax error. Report aborted.
    $return
$label continue
$define input_dir %1%
$define output_dir %2%

$PrintDest %output_dir%/rep_print_def_eqs.a2m A2M 
$PrintNbDec 4

$WsClearAll

$WsLoadCmt %input_dir%/fun.cmt
$WsLoadEqs %input_dir%/fun.eqs
$WsLoadScl %input_dir%/fun.scl

$ $PrintObjDefXxx: print the definition of (an) object(s) in a A2M file

$ $PrintObjInfos: indicate how to print equation(s) definition
$   0: equation only
$   1: equation + comment
$   2: equation + comment + estimation

$ $PrintObjLec: indicate how equations should be printed
$   0: normal LEC form 
$   1: coefficients replaced by their value 
$   2: coefficients replaced by their value + t-tests

`---- print equation only ----`

$PrintObjInfos 0

`normal LEC form`

$PrintObjLec 0
$PrintObjDefEqs ACAF

`coefficients replaced by their value`

$PrintObjLec 1
$PrintObjDefEqs ACAF

`coefficients replaced by their value + t-tests`

$PrintObjLec 2
$PrintObjDefEqs ACAF

`---- print equation + comment ----`

$ set dummy comment
$EqsSetCmt DTF dummy comment

$PrintObjInfos 1

`normal LEC form`

$PrintObjLec 0
$PrintObjDefEqs DTF

`coefficients replaced by their value`

$PrintObjLec 1
$PrintObjDefEqs DTF

`coefficients replaced by their value + t-tests`

$PrintObjLec 2
$PrintObjDefEqs DTF

`---- equation + comment + estimation ----`

$PrintObjInfos 2

`normal LEC form`

$PrintObjLec 0
$PrintObjDefEqs DPUH

`coefficients replaced by their value`

$PrintObjLec 1
$PrintObjDefEqs DPUH

`coefficients replaced by their value + t-tests`

$PrintObjLec 2
$PrintObjDefEqs DPUH

$WsClearAll

$return
