$ report testing if an IODE object exists

$indent
$noparsing
$goto continue {%0% >= 2}
    $show Syntax: rep_fns input_dir output_dir
    $show Syntax error. Report aborted.
    $return
$label continue
$define input_dir %1%
$define output_dir %2%

$PrintDest %output_dir%/rep_data_exist.a2m A2M 

$WsClearAll

$DataUpdateCmt TEST test comment
Comment TEST exist ?: {$DataExistCmt TEST}
$DataDeleteCmt TEST
Deleted comment TEST
Comment TEST exist ?: {$DataExistCmt TEST}

$WsClearAll

$return
